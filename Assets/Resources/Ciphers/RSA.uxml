<ui:UXML xmlns:ui="UnityEngine.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/UI/Gameplay/Ciphers/RSA.uss?fileID=7433441132597879392&amp;guid=1c46b683f0cf4ffb9b5c2244f0a8cade&amp;type=3#RSA"/>
    <ui:VisualElement name="Root" style="flex-grow: 1; background-image: url(&quot;project://database/Assets/UI/Gameplay/Background.png?fileID=-2133662282&amp;guid=b58457c14394ea9439590eeeb6bdabbf&amp;type=3#Background_0&quot;); align-items: center; justify-content: center;">
        <ui:VisualElement name="Tablet" style="flex-grow: 1; background-image: url(&quot;project://database/Assets/UI/Gameplay/Tablet.png?fileID=6063511624963266046&amp;guid=bfe1bd39c35ea6b45ad6ede54d1144ae&amp;type=3#ChatGPT Image 2 февр. 2026 г., 12_00_03_0&quot;); align-items: center; justify-content: center; width: 100%; height: 100%;">
            <ui:VisualElement name="TabletGameArea" style="flex-grow: 0; align-items: center; justify-content: flex-start; width: 1500px; max-width: 1500px; height: auto; padding: 20px 40px; flex-direction: column; scale: 0.75 0.75;">
                <ui:Label text="МОДУЛЬ RSA: ВОССТАНОВЛЕНИЕ ПРИВАТНОГО КЛЮЧА" style="font-size: 28px; color: rgb(97, 235, 97); -unity-font-style: bold; margin-bottom: 20px; letter-spacing: 2px;"/>
                <ui:Button name="InfoButton" text="БАЗА ЗНАНИЙ (ОБ АЛГОРИТМЕ)" style="padding: 10px 20px; font-size: 16px; background-color: rgb(97, 235, 97); color: black; border-radius: 8px; -unity-font-style: bold; margin-bottom: 10px;"/>
                <ui:Label text="Вычислите секретную экспоненту (d) на основе открытых данных (N, e), чтобы расшифровать сообщение." style="font-size: 20px; color: rgb(200, 200, 200); -unity-font-style: italic; margin-bottom: 30px;"/>
                <ui:VisualElement style="flex-direction: row; justify-content: space-around; width: 100%; margin-bottom: 30px;">
                    <ui:VisualElement style="align-items: center; background-color: rgba(0, 0, 0, 0.5); padding: 30px; border-radius: 15px; border-width: 2px; border-color: rgb(200, 200, 200); width: 45%;">
                        <ui:Label text="ПУБЛИЧНЫЙ КЛЮЧ (ПЕРЕХВАЧЕН)" style="font-size: 18px; color: rgb(150, 150, 150); margin-bottom: 15px;"/>
                        <ui:Label name="PublicLabel" text="N = 143     e = 7" style="font-size: 32px; color: rgb(255, 255, 255); -unity-font-style: bold; letter-spacing: 2px;"/>
                    </ui:VisualElement>
                    <ui:VisualElement style="align-items: center; background-color: rgba(0, 0, 0, 0.5); padding: 30px; border-radius: 15px; border-width: 2px; border-color: rgb(200, 200, 200); width: 45%;">
                        <ui:Label text="ЗАШИФРОВАННЫЙ ТЕКСТ" style="font-size: 18px; color: rgb(150, 150, 150); margin-bottom: 15px;"/>
                        <ui:Label name="EncryptedTextLabel" text="[ENCRYPTED HEX]" style="font-size: 32px; color: rgb(235, 97, 97); -unity-font-style: bold; letter-spacing: 2px;"/>
                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement style="flex-direction: row; justify-content: center; align-items: center; background-color: rgba(0, 0, 0, 0.5); padding: 30px; border-radius: 15px; border-width: 2px; border-color: rgb(97, 235, 97); margin-bottom: 30px; width: 100%;">
                    <ui:VisualElement style="align-items: center; margin: 0 15px;">
                        <ui:Label text="ПРОСТОЕ P" style="font-size: 16px; margin-bottom: 5px; -unity-font-style: bold; color: rgb(255, 255, 255);"/>
                        <ui:TextField name="InputP" max-length="3" value="" class="input-field" style="width: 100px; height: 50px;"/>
                    </ui:VisualElement>
                    <ui:VisualElement style="align-items: center; margin: 0 15px;">
                        <ui:Label text="ПРОСТОЕ Q" style="font-size: 16px; margin-bottom: 5px; -unity-font-style: bold; color: rgb(255, 255, 255);"/>
                        <ui:TextField name="InputQ" max-length="3" value="" class="input-field" style="width: 100px; height: 50px;"/>
                    </ui:VisualElement>
                    <ui:VisualElement style="align-items: center; margin: 0 15px;">
                        <ui:Label text="Φ(N)" style="font-size: 16px; margin-bottom: 5px; -unity-font-style: bold; color: rgb(255, 255, 255);"/>
                        <ui:TextField name="InputPhi" max-length="4" value="" class="input-field" style="width: 120px; height: 50px;"/>
                    </ui:VisualElement>
                    <ui:VisualElement style="align-items: center; margin: 0 15px;">
                        <ui:Label text="СЕКРЕТНЫЙ D" style="font-size: 16px; margin-bottom: 5px; -unity-font-style: bold; color: rgb(255, 255, 0);"/>
                        <ui:TextField name="InputD" max-length="4" value="" class="input-field-secret" style="width: 120px; height: 50px;"/>
                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:Label name="StatusLabel" text="ВВЕДИТЕ ДАННЫЕ ДЛЯ ГЕНЕРАЦИИ ПРИВАТНОГО КЛЮЧА" style="font-size: 20px; color: rgb(200, 200, 200); -unity-font-style: bold; margin-bottom: 20px;"/>
                <ui:VisualElement name="ActionButtons" style="flex-direction: row; justify-content: center; align-items: center; width: 100%;">
                    <ui:Button name="SubmitButton" text="ДЕШИФРОВАТЬ ДОКУМЕНТ" style="padding: 15px 45px; font-size: 22px; background-color: rgb(97, 235, 97); color: black; border-radius: 8px; -unity-font-style: bold;"/>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="CheatSheetOverlay" style="position: absolute; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.9); display: none; align-items: center; justify-content: center; z-index: 100;">
                <ui:VisualElement style="background-color: rgb(40, 40, 40); border-width: 2px; border-color: rgb(97, 235, 97); border-radius: 15px; padding: 40px; width: 80%; max-width: 1000px; align-items: center;">
                    <ui:Label text="СПРАВКА: АЛГОРИТМ RSA" style="font-size: 24px; color: rgb(97, 235, 97); -unity-font-style: bold; margin-bottom: 20px;"/>
                    <ui:Label text="Для расшифровки сообщения вам необходим приватный ключ (число d). Зная публичные числа N и e, вы можете найти d путем факторизации." style="font-size: 18px; color: rgb(200, 200, 200); margin-bottom: 15px; white-space: normal; -unity-text-align: middle-center;"/>
                    <ui:Label text="1. Найдите два простых числа P и Q такие, что P × Q = N." style="font-size: 18px; color: rgb(255, 255, 255); margin-bottom: 10px; white-space: normal; -unity-text-align: middle-center;"/>
                    <ui:Label text="2. Вычислите функцию Эйлера: Φ(N) = (P - 1) × (Q - 1)." style="font-size: 18px; color: rgb(255, 255, 255); margin-bottom: 10px; white-space: normal; -unity-text-align: middle-center;"/>
                    <ui:Label text="3. Найдите приватное число D такое, чтобы: (D × e) mod Φ(N) = 1. Иначе говоря, остаток от деления (D × e) на Φ(N) должен равняться 1." style="font-size: 18px; color: rgb(255, 255, 255); margin-bottom: 20px; white-space: normal; -unity-text-align: middle-center;"/>
                    <ui:Label text="Пример: e=3, Φ(N)=20. Ищем D. 3D должно давать остаток 1 при делении на 20. Подходит D=7 (37=21, 21 mod 20 = 1)." style="font-size: 16px; color: rgb(150, 150, 150); margin-bottom: 30px; white-space: normal; -unity-text-align: middle-center; -unity-font-style: italic;"/>
                    <ui:Button name="CloseInfoButton" text="ПОНЯТНО" style="padding: 15px 40px; font-size: 20px; background-color: rgb(97, 235, 97); color: black; border-radius: 8px; -unity-font-style: bold; margin-top: 10px;"/>
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
